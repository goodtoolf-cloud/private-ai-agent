# FILE: .env.example
# Copy this file to .env and fill in your values

# ── Cloudflare Workers AI (FREE — get from dash.cloudflare.com) ─────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# ── Database (auto-created by Docker Compose) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_user:ai_pass@postgres:5432/ai_agent

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars

# ── E2B Code Sandbox (optional — for isolated code execution) ────────────────
# Get free API key at https://e2b.dev
# If left empty, code runs locally with a 30s timeout
E2B_API_KEY=

# ── LibreTranslate (optional self-hosted — leave blank to use public API) ────
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

# ── Piper TTS model path (inside Docker container) ───────────────────────────
PIPER_MODEL=/app/models/piper/en_US-lessac-medium.onnx
